<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:PreExamen.ViewModels"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             x:DataType="viewModels:MainWindowViewModel"
             mc:Ignorable="d"
             d:DesignWidth="450"
             d:DesignHeight="550"
             Width="450"
             Height="550"
             x:Class="PreExamen.Views.Dialogs.CarritoDialog">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Grid RowDefinitions="40,*,40,40">
            <TextBlock Grid.Row="0"
                       Text="ERCICARRITO"
                       HorizontalAlignment="Center"
                       FontSize="35"
                       FontWeight="Bold"
                       Margin="3" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding CarritoFrutas }"
                     Name="ListaFrutas"
                     HorizontalAlignment="Center"
                     SelectionMode="Single, Toggle">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem:selected controls|Card">
                        <Setter Property="Background"
                                Value="Aquamarine" />
                        <Setter Property="BorderBrush"
                                Value="Blue" />
                        <Setter Property="BorderThickness"
                                Value="2" />
                    </Style>
                </ListBox.Styles>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>
                        <controls:Card Height="100"
                                       Width="450"
                                       VerticalAlignment="Top">
                            <StackPanel Margin="0,4"
                                        Orientation="Horizontal"
                                        Background="AliceBlue">
                                <Image Width="50"
                                       Height="50"
                                       Margin="10"
                                       Source="{Binding ImagePath}" />
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Foreground="Black"
                                               FontWeight="Bold"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding Name}" />
                                    <TextBlock Foreground="Black"
                                               FontWeight="Bold"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding CantidadKg, StringFormat='CANTIDAD: {0} KG'}" />
                                </StackPanel>


                            </StackPanel>
                        </controls:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Spacing="5"
                        HorizontalAlignment="Center"
                        Grid.Row="2">
                <TextBlock Text="CANTIDAD:"
                           VerticalAlignment="Center" />
                <TextBox Width="40"
                         VerticalAlignment="Center" />
                <TextBlock Text="KG:"
                           VerticalAlignment="Center" />
            </StackPanel>
            
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="5"
                        Margin="5"
                        HorizontalAlignment="Center">
                <Button Content="ELIMINAR"
                        Width="120" />
                <Button Content="ACTUALIZAR"
                        Width="120" />
            </StackPanel>
        </Grid>
    </Grid>


</UserControl>